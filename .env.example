# Copy this file to .env and fill in the values before running docker compose.

# SQL Server SA password — must meet complexity: upper+lower+digit+symbol, 8+ chars
SA_PASSWORD=YourStrong@Password123

# JWT signing key — must be 32+ characters.
# Copy the value from your dotnet user-secrets (Jwt:Key) to keep existing sessions valid.
JWT_KEY=budget-app-super-secret-key-change-in-production-32chars!!
